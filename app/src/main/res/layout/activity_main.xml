<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Project Management"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etProjectIdCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Project ID/Code *" />

        <EditText
            android:id="@+id/etProjectName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Project Name *" />

        <EditText
            android:id="@+id/etDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Destination *" />

        <EditText
            android:id="@+id/etStartDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Start Date (dd/mm/yyyy) *" />

        <EditText
            android:id="@+id/etEndDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="End Date (dd/mm/yyyy) *" />

        <EditText
            android:id="@+id/etBudget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Budget ($) *"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Project Owner *" />

        <EditText
            android:id="@+id/etStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Status (Active/Completed/On Hold) *" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Project Description *"
            android:gravity="top"
            android:lines="3" />
        <EditText
            android:id="@+id/etSpecialRequirements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Special Requirements (Optional)" />

        <EditText
            android:id="@+id/etClientInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Client/Department Information (Optional)" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Requires Risk Assessment?"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnSaveProject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Project"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnViewProjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View All Projects"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />


    </LinearLayout>
</ScrollView>